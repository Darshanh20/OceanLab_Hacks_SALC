{
  "version": 2,
  "env": {
    "SUPABASE_URL": {
      "description": "Supabase database URL",
      "required": true,
      "example": "https://your-project.supabase.co"
    },
    "SUPABASE_KEY": {
      "description": "Supabase anon key",
      "required": true,
      "example": "eyJxxx..."
    },
    "SUPABASE_SERVICE_ROLE": {
      "description": "Supabase service role key",
      "required": true,
      "example": "eyJxxx..."
    },
    "SECRET_KEY": {
      "description": "JWT secret key (min 32 chars)",
      "required": true,
      "example": "your-secret-key-minimum-32-characters-long"
    },
    "ALGORITHM": {
      "description": "JWT algorithm",
      "required": false,
      "example": "HS256"
    },
    "ACCESS_TOKEN_EXPIRE_MINUTES": {
      "description": "Token expiration in minutes",
      "required": false,
      "example": "1440"
    },
    "GROQ_API_KEY": {
      "description": "Groq API key for LLM",
      "required": false,
      "example": "gsk_xxx..."
    },
    "COHERE_API_KEY": {
      "description": "Cohere API key (alternative LLM)",
      "required": false,
      "example": "xxx..."
    },
    "GOOGLE_API_KEY": {
      "description": "Google API key (optional, for Drive/YouTube)",
      "required": false,
      "example": "xxx..."
    }
  },
  "buildCommand": "pip install -r requirements.txt",
  "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "functions": {
    "app/**/*.py": {
      "runtime": "python3.11"
    }
  }
}
